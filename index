<script>


    
    // Free Discord access modal. Opens only when a Free Discord CTA is clicked.
    const leadModal = document.getElementById('leadModal');
    const leadModalClose = document.getElementById('leadModalClose');
    const leadForm = document.getElementById('leadForm');
    const leadNextStep = document.getElementById('leadNextStep');
    const leadBackStep = document.getElementById('leadBackStep');
    const discordInviteUrl = "https://discord.gg/2m2VnxhXwp";

    function setLeadStep(stepNumber) {
      if (!leadForm) return;
      leadForm.querySelectorAll('.lead-step').forEach(step => {
        step.classList.toggle('active', step.dataset.step === String(stepNumber));
      });
    }

    function openLeadModal(event) {
      if (event) event.preventDefault();
      if (!leadModal) return;
      setLeadStep(1);
      leadModal.classList.add('open');
      leadModal.setAttribute('aria-hidden', 'false');
      document.body.classList.add('modal-open');
      const firstInput = leadModal.querySelector('input[name="fullName"]');
      setTimeout(() => firstInput && firstInput.focus(), 180);
    }

    function closeLeadModal() {
      if (!leadModal) return;
      leadModal.classList.remove('open');
      leadModal.setAttribute('aria-hidden', 'true');
      document.body.classList.remove('modal-open');
    }

    function validatePersonalInfo() {
      if (!leadForm) return false;
      const fields = [
        leadForm.querySelector('input[name="fullName"]'),
        leadForm.querySelector('input[name="email"]'),
        leadForm.querySelector('input[name="phone"]')
      ];
      for (const field of fields) {
        if (!field || !field.checkValidity()) {
          if (field) field.reportValidity();
          return false;
        }
      }
      return true;
    }

    document.querySelectorAll('.open-discord-modal').forEach(trigger => {
      trigger.addEventListener('click', openLeadModal);
    });

    if (leadNextStep) {
      leadNextStep.addEventListener('click', () => {
        if (validatePersonalInfo()) setLeadStep(2);
      });
    }

    if (leadBackStep) leadBackStep.addEventListener('click', () => setLeadStep(1));
    if (leadModalClose) leadModalClose.addEventListener('click', closeLeadModal);

    if (leadModal) {
      leadModal.addEventListener('click', event => {
        if (event.target === leadModal) closeLeadModal();
      });
    }

    document.addEventListener('keydown', event => {
      if (event.key === 'Escape') closeLeadModal();
    });

    if (leadForm) {
      leadForm.addEventListener('submit', event => {
        event.preventDefault();

        if (!validatePersonalInfo()) {
          setLeadStep(1);
          return;
        }

        const selectedStruggle = leadForm.querySelector('input[name="tradingStruggle"]:checked');
        if (!selectedStruggle) {
          setLeadStep(2);
          const firstRadio = leadForm.querySelector('input[name="tradingStruggle"]');
          if (firstRadio) firstRadio.reportValidity();
          return;
        }

        const data = Object.fromEntries(new FormData(leadForm).entries());
        const leads = JSON.parse(localStorage.getItem('bmTradingDiscordLeads') || '[]');
        leads.push({ ...data, submittedAt: new Date().toISOString() });
        localStorage.setItem('bmTradingDiscordLeads', JSON.stringify(leads));

        window.location.href = discordInviteUrl;
      });
    }

    // Smooth polish pass: page load, scroll progress, sticky nav state, active nav link, dynamic FAQ height.
    window.addEventListener('load', () => {
      document.body.classList.remove('page-loading');
      document.body.classList.add('loaded');
    });

    const scrollProgress = document.getElementById('scrollProgress');
    const nav = document.querySelector('.nav');

    function updateScrollUI() {
      const scrollable = document.documentElement.scrollHeight - window.innerHeight;
      const progress = scrollable > 0 ? (window.scrollY / scrollable) * 100 : 0;
      if (scrollProgress) scrollProgress.style.width = `${progress}%`;
      if (nav) nav.classList.toggle('scrolled', window.scrollY > 18);
    }

    window.addEventListener('scroll', updateScrollUI, { passive: true });
    updateScrollUI();

    const navAnchorLinks = Array.from(document.querySelectorAll('.nav-links a[href^="#"]')).filter(link => link.getAttribute('href').length > 1);
    const sectionsForNav = navAnchorLinks
      .map(link => document.querySelector(link.getAttribute('href')))
      .filter(Boolean);

    const activeNavObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (!entry.isIntersecting) return;
        const id = `#${entry.target.id}`;
        navAnchorLinks.forEach(link => link.classList.toggle('active', link.getAttribute('href') === id));
      });
    }, { rootMargin: '-35% 0px -55% 0px', threshold: 0 });

    sectionsForNav.forEach(section => activeNavObserver.observe(section));

    function setFaqHeights() {
      document.querySelectorAll('.faq-item').forEach(item => {
        const answer = item.querySelector('.faq-answer');
        if (!answer) return;
        item.style.setProperty('--faq-height', `${answer.scrollHeight}px`);
      });
    }

    setFaqHeights();
    window.addEventListener('resize', setFaqHeights);

    const mobileToggle = document.getElementById('mobileToggle');
    const navLinks = document.getElementById('navLinks');

    mobileToggle.addEventListener('click', () => {
      navLinks.classList.toggle('open');
      mobileToggle.textContent = navLinks.classList.contains('open') ? '×' : '☰';
    });

    navLinks.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        navLinks.classList.remove('open');
        mobileToggle.textContent = '☰';
      });
    });

    const revealEls = document.querySelectorAll('.reveal');
    const revealObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) entry.target.classList.add('show');
      });
    }, { threshold: 0.15 });

    revealEls.forEach(el => revealObserver.observe(el));

    const faqItems = document.querySelectorAll('.faq-item');
    function closeMobileDefaultFaq() {
      if (window.innerWidth <= 760) {
        faqItems.forEach(item => item.classList.remove('active'));
      }
      setFaqHeights();
    }

    closeMobileDefaultFaq();
    window.addEventListener('resize', closeMobileDefaultFaq);

    faqItems.forEach(item => {
      const btn = item.querySelector('.faq-question');
      btn.addEventListener('click', () => {
        setFaqHeights();
        const wasActive = item.classList.contains('active');
        faqItems.forEach(otherItem => otherItem.classList.remove('active'));
        if (!wasActive) item.classList.add('active');
        setFaqHeights();
      });
    });

    const track = document.getElementById('reviewTrack');
    const reviews = Array.from(track.children);
    const next = document.getElementById('nextReview');
    const prev = document.getElementById('prevReview');
    let reviewIndex = 0;

    function visibleCount() {
      if (window.innerWidth <= 760) return 1;
      if (window.innerWidth <= 980) return 2;
      return 3;
    }

    function updateCarousel() { return; }

    if (next) if (next) next.addEventListener('click', () => {
      const maxIndex = Math.max(0, reviews.length - visibleCount());
      reviewIndex = reviewIndex >= maxIndex ? 0 : reviewIndex + 1;
      updateCarousel();
    });

    if (prev) if (prev) prev.addEventListener('click', () => {
      const maxIndex = Math.max(0, reviews.length - visibleCount());
      reviewIndex = reviewIndex <= 0 ? maxIndex : reviewIndex - 1;
      updateCarousel();
    });

    window.addEventListener('resize', updateCarousel);
    updateCarousel();

    const terminalCard = document.querySelector('.terminal-card');
    if (terminalCard && window.matchMedia('(pointer: fine)').matches) {
      terminalCard.addEventListener('mousemove', (event) => {
        const rect = terminalCard.getBoundingClientRect();
        const x = event.clientX - rect.left;
        const y = event.clientY - rect.top;
        const rotateY = ((x / rect.width) - .5) * 8;
        const rotateX = -((y / rect.height) - .5) * 8;
        terminalCard.style.transform = `perspective(900px) rotateX(${rotateX}deg) rotateY(${rotateY}deg)`;
      });

      terminalCard.addEventListener('mouseleave', () => {
        terminalCard.style.transform = '';
      });
    }


    // Animated NQ-style candle chart backsplash in hero.
    (() => {
      const canvas = document.getElementById('marketCanvas');
      if (!canvas) return;
      const ctx = canvas.getContext('2d');
      let dpr = window.devicePixelRatio || 1;
      let W = 0, H = 0;
      let candles = [];
      let lastSpawn = 0;
      let price = 18525;
      const maxCandles = 82;

      function resizeMarketCanvas(){
        dpr = window.devicePixelRatio || 1;
        W = canvas.clientWidth;
        H = canvas.clientHeight;
        canvas.width = Math.floor(W * dpr);
        canvas.height = Math.floor(H * dpr);
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      }

      function seedCandles(){
        candles = [];
        price = 18520;
        for(let i=0;i<maxCandles;i++){
          const open = price;
          const volatility = i > maxCandles - 20 ? 36 : 18;
          const drift = i > maxCandles - 26 ? (Math.random() * 24 - 5) : (Math.random() * 16 - 8);
          const close = open + drift;
          const high = Math.max(open, close) + Math.random() * volatility;
          const low = Math.min(open, close) - Math.random() * volatility;
          const vol = (i > maxCandles - 20 ? 0.58 : 0.22) + Math.random() * .7;
          candles.push({open, close, high, low, vol, flash: Math.random() * .6});
          price = close;
        }
      }

      function addCandle(){
        const open = price;
        const openRush = Math.random() > .36;
        const close = open + (openRush ? Math.random() * 42 - 13 : Math.random() * 24 - 12);
        const high = Math.max(open, close) + 10 + Math.random() * 28;
        const low = Math.min(open, close) - 8 - Math.random() * 24;
        const vol = .55 + Math.random() * 1.05;
        candles.push({open, close, high, low, vol, flash: 1});
        if(candles.length > maxCandles) candles.shift();
        price = close;
      }

      function mapY(value, min, max){
        const top = H * .10, bottom = H * .82;
        return bottom - ((value - min) / (max - min || 1)) * (bottom - top);
      }

      function drawMarket(ts){
        if(!W || !H) resizeMarketCanvas();
        if(!candles.length) seedCandles();
        if(ts - lastSpawn > 430){ addCandle(); lastSpawn = ts; }
        ctx.clearRect(0,0,W,H);
        ctx.fillStyle = '#000';
        ctx.fillRect(0,0,W,H);

        const highs = candles.map(c=>c.high), lows = candles.map(c=>c.low);
        const max = Math.max(...highs) + 24, min = Math.min(...lows) - 24;
        const left = W * .06, right = W * .92;
        const top = H * .10, bottom = H * .82;
        const chartW = right - left;
        const gap = Math.max(3, chartW / maxCandles * .22);
        const cw = (chartW / maxCandles) - gap;
        const slide = ((ts % 430) / 430) * (cw + gap);

        ctx.strokeStyle = 'rgba(255,255,255,.07)';
        ctx.lineWidth = 1;
        for(let i=0;i<10;i++){
          const y = top + (bottom-top) * i/9;
          ctx.beginPath(); ctx.moveTo(left, y); ctx.lineTo(W*.96, y); ctx.stroke();
        }
        for(let i=0;i<14;i++){
          const x = left + chartW * i/13 - slide * .25;
          ctx.beginPath(); ctx.moveTo(x, top); ctx.lineTo(x, bottom + H*.10); ctx.stroke();
        }

        candles.forEach((c, i)=>{
          const x = left + i * (cw + gap) - slide;
          if(x < left - 40 || x > W*.95) return;
          const yO = mapY(c.open,min,max), yC = mapY(c.close,min,max), yH = mapY(c.high,min,max), yL = mapY(c.low,min,max);
          const up = c.close >= c.open;
          const bodyTop = Math.min(yO,yC);
          const bodyH = Math.max(2, Math.abs(yC-yO));
          const alpha = .22 + (i / candles.length) * .64;
          ctx.strokeStyle = up ? `rgba(255,255,255,${alpha})` : `rgba(150,150,155,${alpha})`;
          ctx.fillStyle = up ? `rgba(255,255,255,${alpha*.86})` : `rgba(0,0,0,${.26 + alpha*.28})`;
          ctx.lineWidth = 1.2;
          ctx.beginPath(); ctx.moveTo(x + cw/2, yH); ctx.lineTo(x + cw/2, yL); ctx.stroke();
          ctx.fillRect(x, bodyTop, cw, bodyH);
          if(!up){ ctx.strokeRect(x+.5, bodyTop+.5, cw-1, bodyH-1); }
          if(c.flash > .02){
            ctx.strokeStyle = `rgba(255,255,255,${c.flash*.34})`;
            ctx.strokeRect(x-3, bodyTop-3, cw+6, bodyH+6);
            c.flash *= .92;
          }
          const volH = Math.min(H*.12, H*.025 + c.vol * H*.08);
          ctx.fillStyle = `rgba(255,255,255,${.08 + c.vol*.07})`;
          ctx.fillRect(x, bottom + H*.055 + (H*.12 - volH), cw, volH);
        });

        const currentY = mapY(price, min, max);
        ctx.strokeStyle = 'rgba(255,255,255,.26)';
        ctx.beginPath(); ctx.moveTo(left, currentY); ctx.lineTo(W*.91, currentY); ctx.stroke();

        const liquidityY = mapY(price + 34, min, max);
        const glowPulse = 0.50 + Math.sin(ts / 700) * 0.18;
        ctx.save();
        ctx.shadowColor = 'rgba(201,145,115,.70)';
        ctx.shadowBlur = 16;
        ctx.strokeStyle = `rgba(201,145,115,${glowPulse})`;
        ctx.lineWidth = 1.35;
        ctx.setLineDash([10, 7]);
        ctx.beginPath(); ctx.moveTo(left, liquidityY); ctx.lineTo(W * .88, liquidityY); ctx.stroke();
        ctx.setLineDash([]);
        ctx.shadowBlur = 0;
        ctx.fillStyle = 'rgba(201,145,115,.82)';
        ctx.font = '600 11px ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace';
        ctx.fillText('LIQUIDITY', left + 8, liquidityY - 8);
        ctx.restore();

        const panelX = W*.07, panelY = H*.86;
        ctx.font = '500 11px ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace';
        for(let i=0;i<22;i++){
          const x = panelX + i * 38 - ((ts/24)%38);
          const h = 4 + Math.random()*20;
          ctx.fillStyle = `rgba(255,255,255,${.10 + Math.random()*.20})`;
          ctx.fillRect(x, panelY + 30 - h, 22, h);
        }
        ctx.fillStyle = 'rgba(255,255,255,.34)';
        ctx.fillText('NQ MARKET OPEN • LIVE FLOW • LIQUIDITY LEVELS', panelX, panelY);

        requestAnimationFrame(drawMarket);
      }
      window.addEventListener('resize', resizeMarketCanvas);
      resizeMarketCanvas(); seedCandles(); requestAnimationFrame(drawMarket);
    })();

  </script>
</body>
</html>
