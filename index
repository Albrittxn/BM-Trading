<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1" name="viewport"/>
<title>BM Trading — Midnight Violet Day Trading Mentorship</title>
<meta content="BM Trading mentorship for beginner and struggling traders. Midnight Violet website direction with a systematic, rule-based approach using derivatives data, positioning, and key market levels." name="description"/>
<link href="https://fonts.googleapis.com" rel="preconnect"/>
<link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect"/>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&amp;display=swap" rel="stylesheet"/>
<style>
    :root {
      --bg: #07090d;
      --bg-2: #0b0f16;
      --card: rgba(255,255,255,.055);
      --card-2: rgba(255,255,255,.08);
      --line: rgba(255,255,255,.12);
      --text: #F8FAFC;
      --muted: #a8b0c2;
      --soft: #70798d;
      --purple: #8B5CF6;
      --purple-2: #7C3AED;
      --purple: #A78BFA;
      --purple-alt: #C084FC;
      --shadow: 0 24px 80px rgba(0,0,0,.44);
      --radius: 26px;
      --radius-sm: 16px;
      --max: 1180px;
    }

    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      margin: 0;
      font-family: Inter, system-ui, -apple-system, Segoe UI, sans-serif;
      background:
        radial-gradient(circle at 22% 2%, rgba(139,92,246,.14), transparent 34rem),
        radial-gradient(circle at 82% 14%, rgba(192,132,252,.13), transparent 32rem),
        radial-gradient(circle at 52% 86%, rgba(167,139,250,.09), transparent 34rem),
        var(--bg);
      color: var(--text);
      overflow-x: hidden;
    }

    body::before {
      content: "";
      position: fixed;
      inset: 0;
      pointer-events: none;
      background-image:
        linear-gradient(rgba(255,255,255,.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,.03) 1px, transparent 1px);
      background-size: 72px 72px;
      mask-image: linear-gradient(to bottom, rgba(0,0,0,.78), transparent 85%);
      z-index: -2;
    }

    a { color: inherit; text-decoration: none; }
    button, a { -webkit-tap-highlight-color: transparent; }

    .container {
      width: min(var(--max), calc(100% - 40px));
      margin: 0 auto;
    }

    .nav {
      position: sticky;
      top: 0;
      z-index: 50;
      backdrop-filter: blur(18px);
      background: rgba(7,9,13,.68);
      border-bottom: 1px solid rgba(255,255,255,.08);
    }

    .nav-inner {
      height: 76px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 22px;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 12px;
      font-weight: 800;
      letter-spacing: -.04em;
      font-size: 1.15rem;
    }

    .mark {
      width: 42px;
      height: 42px;
      border-radius: 14px;
      display: grid;
      place-items: center;
      color: #07090d;
      font-weight: 900;
      letter-spacing: -.08em;
      background:
        linear-gradient(135deg, #EDE9FE, var(--purple) 52%, #5B21B6);
      box-shadow: 0 12px 34px rgba(139,92,246,.25), inset 0 1px 0 rgba(255,255,255,.55);
    }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 24px;
      color: var(--muted);
      font-size: .92rem;
      font-weight: 600;
    }

    .nav-links a:hover { color: var(--text); }

    .nav-cta {
      display: inline-flex;
      align-items: center;
      gap: 9px;
      padding: 12px 17px;
      border-radius: 999px;
      background: rgba(255,255,255,.08);
      border: 1px solid rgba(255,255,255,.13);
      font-weight: 700;
      transition: transform .22s ease, background .22s ease, border .22s ease;
    }

    .nav-cta:hover {
      transform: translateY(-2px);
      background: rgba(139,92,246,.14);
      border-color: rgba(139,92,246,.33);
    }

    .mobile-toggle {
      display: none;
      border: 0;
      background: rgba(255,255,255,.08);
      color: var(--text);
      border-radius: 12px;
      width: 42px;
      height: 42px;
      font-size: 1.3rem;
    }

    .hero {
      position: relative;
      padding: 86px 0 54px;
    }

    .hero-grid {
      display: grid;
      grid-template-columns: 1.08fr .92fr;
      gap: 52px;
      align-items: center;
    }

    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 9px;
      width: fit-content;
      color: #DDD6FE;
      background: rgba(139,92,246,.1);
      border: 1px solid rgba(139,92,246,.24);
      border-radius: 999px;
      padding: 9px 13px;
      font-weight: 700;
      font-size: .85rem;
      box-shadow: inset 0 1px 0 rgba(255,255,255,.08);
    }

    .pulse {
      width: 8px;
      height: 8px;
      border-radius: 999px;
      background: var(--purple);
      box-shadow: 0 0 0 0 rgba(167,139,250,.65);
      animation: pulse 1.8s infinite;
    }

    @keyframes pulse {
      70% { box-shadow: 0 0 0 10px rgba(167,139,250,0); }
      100% { box-shadow: 0 0 0 0 rgba(167,139,250,0); }
    }

    h1 {
      margin: 24px 0 18px;
      font-size: clamp(3rem, 7vw, 6.7rem);
      line-height: .88;
      letter-spacing: -.085em;
      max-width: 850px;
    }

    .gradient-text {
      background: linear-gradient(110deg, #fff 10%, #e7edf9 36%, #8B5CF6 71%, #EDE9FE);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }

    .hero-copy {
      color: var(--muted);
      font-size: clamp(1.02rem, 1.8vw, 1.25rem);
      line-height: 1.75;
      max-width: 690px;
      margin: 0 0 28px;
    }

    .hero-actions {
      display: flex;
      gap: 13px;
      flex-wrap: wrap;
      align-items: center;
      margin-bottom: 28px;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      min-height: 52px;
      padding: 0 21px;
      border-radius: 999px;
      font-weight: 800;
      transition: transform .22s ease, box-shadow .22s ease, border .22s ease, background .22s ease;
      cursor: pointer;
    }

    .btn-primary {
      color: #080a0f;
      background: linear-gradient(135deg, #EDE9FE, var(--purple) 55%, var(--purple-2));
      box-shadow: 0 18px 48px rgba(139,92,246,.25);
    }

    .btn-primary:hover {
      transform: translateY(-3px);
      box-shadow: 0 26px 64px rgba(139,92,246,.32);
    }

    .btn-secondary {
      color: var(--text);
      background: rgba(255,255,255,.07);
      border: 1px solid rgba(255,255,255,.13);
    }

    .btn-secondary:hover {
      transform: translateY(-3px);
      border-color: rgba(255,255,255,.25);
      background: rgba(255,255,255,.1);
    }

    .trust-row {
      display: flex;
      flex-wrap: wrap;
      gap: 13px;
      color: var(--muted);
      font-size: .92rem;
      font-weight: 600;
    }

    .trust-pill {
      border: 1px solid rgba(255,255,255,.11);
      background: rgba(255,255,255,.045);
      border-radius: 999px;
      padding: 10px 13px;
    }

    .terminal-card {
      position: relative;
      border-radius: var(--radius);
      background:
        linear-gradient(180deg, rgba(255,255,255,.09), rgba(255,255,255,.04)),
        rgba(255,255,255,.04);
      border: 1px solid rgba(255,255,255,.12);
      box-shadow: var(--shadow);
      overflow: hidden;
      transform-style: preserve-3d;
      animation: float 7s ease-in-out infinite;
    }

    @keyframes float {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-14px); }
    }

    .terminal-card::before {
      content: "";
      position: absolute;
      inset: -1px;
      background:
        radial-gradient(circle at 18% 10%, rgba(139,92,246,.28), transparent 18rem),
        radial-gradient(circle at 80% 30%, rgba(192,132,252,.18), transparent 16rem);
      opacity: .75;
      pointer-events: none;
    }

    .terminal-top {
      position: relative;
      padding: 18px 18px 0;
      display: flex;
      justify-content: space-between;
      align-items: center;
      color: var(--muted);
      font-size: .85rem;
      font-weight: 700;
    }

    .dots {
      display: flex;
      gap: 7px;
    }

    .dot {
      width: 10px;
      height: 10px;
      border-radius: 99px;
      background: rgba(255,255,255,.28);
    }

    .chart {
      position: relative;
      height: 350px;
      margin: 8px 18px 18px;
      border-radius: 20px;
      overflow: hidden;
      background:
        linear-gradient(to bottom, rgba(255,255,255,.06), transparent),
        repeating-linear-gradient(to right, rgba(255,255,255,.06) 0 1px, transparent 1px 52px),
        repeating-linear-gradient(to bottom, rgba(255,255,255,.06) 0 1px, transparent 1px 52px),
        rgba(0,0,0,.22);
      border: 1px solid rgba(255,255,255,.08);
    }

    .chart svg {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
    }

    .chart-line {
      stroke-dasharray: 900;
      stroke-dashoffset: 900;
      animation: draw 2.5s ease forwards .35s;
    }

    @keyframes draw { to { stroke-dashoffset: 0; } }

    .level {
      position: absolute;
      left: 18px;
      right: 18px;
      height: 1px;
      background: rgba(139,92,246,.48);
    }

    .level.one { top: 34%; }
    .level.two { bottom: 25%; background: rgba(167,139,250,.42); }

    .level span {
      position: absolute;
      right: 0;
      top: -13px;
      font-size: .72rem;
      color: #DDD6FE;
      background: rgba(0,0,0,.36);
      padding: 5px 7px;
      border-radius: 999px;
      border: 1px solid rgba(255,255,255,.08);
    }

    .mini-panel {
      position: absolute;
      left: 24px;
      bottom: 24px;
      width: min(290px, calc(100% - 48px));
      background: rgba(8,10,15,.76);
      backdrop-filter: blur(14px);
      border: 1px solid rgba(255,255,255,.12);
      border-radius: 18px;
      padding: 15px;
      box-shadow: 0 20px 60px rgba(0,0,0,.35);
    }

    .mini-row {
      display: flex;
      justify-content: space-between;
      gap: 20px;
      padding: 8px 0;
      border-bottom: 1px solid rgba(255,255,255,.08);
      font-size: .86rem;
      color: var(--muted);
    }

    .mini-row:last-child { border-bottom: 0; }
    .mini-row strong { color: var(--text); }

    section {
      padding: 72px 0;
      position: relative;
    }

    .section-head {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      gap: 24px;
      margin-bottom: 30px;
    }

    .section-kicker {
      color: var(--purple);
      font-size: .86rem;
      font-weight: 900;
      letter-spacing: .12em;
      text-transform: uppercase;
      margin-bottom: 12px;
    }

    h2 {
      margin: 0;
      font-size: clamp(2rem, 4vw, 3.9rem);
      line-height: 1;
      letter-spacing: -.065em;
    }

    .section-copy {
      margin: 0;
      max-width: 510px;
      color: var(--muted);
      line-height: 1.7;
    }

    .features {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
    }

    .feature-card {
      padding: 25px;
      border-radius: var(--radius);
      background: rgba(255,255,255,.05);
      border: 1px solid rgba(255,255,255,.1);
      box-shadow: 0 18px 70px rgba(0,0,0,.18);
      transition: transform .24s ease, background .24s ease, border .24s ease;
    }

    .feature-card:hover {
      transform: translateY(-7px);
      background: rgba(255,255,255,.075);
      border-color: rgba(139,92,246,.25);
    }

    .icon {
      width: 46px;
      height: 46px;
      border-radius: 15px;
      display: grid;
      place-items: center;
      background: rgba(139,92,246,.12);
      border: 1px solid rgba(139,92,246,.22);
      margin-bottom: 18px;
      color: var(--purple);
      font-size: 1.2rem;
    }

    .feature-card h3,
    .plan h3 {
      margin: 0 0 10px;
      font-size: 1.24rem;
      letter-spacing: -.035em;
    }

    .feature-card p,
    .plan p {
      margin: 0;
      color: var(--muted);
      line-height: 1.68;
    }

    .process {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 14px;
      counter-reset: step;
    }

    .step {
      position: relative;
      padding: 22px;
      border-radius: 22px;
      background: rgba(255,255,255,.045);
      border: 1px solid rgba(255,255,255,.1);
      min-height: 220px;
      overflow: hidden;
    }

    .step::before {
      counter-increment: step;
      content: "0" counter(step);
      display: inline-grid;
      place-items: center;
      width: 42px;
      height: 42px;
      border-radius: 14px;
      background: rgba(255,255,255,.08);
      border: 1px solid rgba(255,255,255,.11);
      color: var(--purple);
      font-weight: 900;
      margin-bottom: 42px;
    }

    .step::after {
      content: "";
      position: absolute;
      width: 170px;
      height: 170px;
      border-radius: 999px;
      background: rgba(139,92,246,.08);
      right: -80px;
      top: -80px;
      filter: blur(2px);
    }

    .step h3 { margin: 0 0 9px; letter-spacing: -.04em; }
    .step p { margin: 0; color: var(--muted); line-height: 1.65; font-size: .95rem; }

    .pricing-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 18px;
      align-items: stretch;
    }

    .plan {
      position: relative;
      display: flex;
      flex-direction: column;
      padding: 25px;
      border-radius: var(--radius);
      background:
        linear-gradient(180deg, rgba(255,255,255,.075), rgba(255,255,255,.04));
      border: 1px solid rgba(255,255,255,.11);
      min-height: 520px;
      overflow: hidden;
      transition: transform .24s ease, border .24s ease, box-shadow .24s ease;
    }

    .plan:hover {
      transform: translateY(-8px);
      border-color: rgba(139,92,246,.28);
      box-shadow: 0 28px 90px rgba(0,0,0,.28);
    }

    .plan.featured {
      background:
        radial-gradient(circle at 50% 0%, rgba(139,92,246,.18), transparent 18rem),
        linear-gradient(180deg, rgba(255,255,255,.09), rgba(255,255,255,.045));
      border-color: rgba(139,92,246,.34);
      box-shadow: 0 22px 80px rgba(139,92,246,.08);
    }

    .badge {
      width: fit-content;
      color: #0c0d10;
      background: linear-gradient(135deg, #fff2c1, var(--purple));
      border-radius: 999px;
      padding: 7px 11px;
      font-weight: 900;
      font-size: .75rem;
      margin-bottom: 16px;
    }

    .price {
      margin: 20px 0 4px;
      display: flex;
      align-items: end;
      gap: 6px;
      letter-spacing: -.06em;
      font-weight: 900;
      font-size: 3rem;
    }

    .price span {
      color: var(--muted);
      font-size: 1rem;
      letter-spacing: 0;
      font-weight: 700;
      margin-bottom: 8px;
    }

    .plan-list {
      list-style: none;
      margin: 24px 0 28px;
      padding: 0;
      display: grid;
      gap: 13px;
      color: var(--muted);
      line-height: 1.45;
    }

    .plan-list li {
      display: grid;
      grid-template-columns: 22px 1fr;
      gap: 9px;
      align-items: start;
    }

    .check {
      width: 20px;
      height: 20px;
      border-radius: 99px;
      display: grid;
      place-items: center;
      color: #07100d;
      background: var(--purple);
      font-size: .75rem;
      font-weight: 900;
      margin-top: 1px;
    }

    .plan .btn {
      margin-top: auto;
      width: 100%;
    }

    .reviews-shell {
      border-radius: calc(var(--radius) + 8px);
      border: 1px solid rgba(255,255,255,.11);
      background:
        radial-gradient(circle at 20% 0%, rgba(139,92,246,.12), transparent 26rem),
        rgba(255,255,255,.045);
      padding: 22px;
      overflow: hidden;
    }

    .reviews-toolbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 18px;
      margin-bottom: 18px;
    }

    .stars {
      color: #8B5CF6;
      letter-spacing: 2px;
      font-size: 1.1rem;
    }

    .carousel-controls {
      display: flex;
      gap: 9px;
    }

    .circle-btn {
      width: 42px;
      height: 42px;
      border-radius: 999px;
      border: 1px solid rgba(255,255,255,.13);
      color: var(--text);
      background: rgba(255,255,255,.06);
      cursor: pointer;
      font-size: 1.15rem;
      transition: transform .2s ease, background .2s ease;
    }

    .circle-btn:hover {
      transform: translateY(-2px);
      background: rgba(255,255,255,.1);
    }

    .carousel-window {
      overflow: hidden;
    }

    .review-track {
      display: flex;
      transition: transform .55s cubic-bezier(.22, .8, .2, 1);
    }

    .review {
      flex: 0 0 33.333%;
      padding: 10px;
    }

    .review-card {
      height: 100%;
      min-height: 300px;
      border-radius: 22px;
      padding: 22px;
      background: rgba(0,0,0,.18);
      border: 1px solid rgba(255,255,255,.1);
    }

    .review-head {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 15px;
    }

    .avatar {
      width: 45px;
      height: 45px;
      border-radius: 999px;
      display: grid;
      place-items: center;
      color: #111318;
      font-weight: 900;
      background: linear-gradient(135deg, #f7f0d3, var(--purple));
    }

    .review-name {
      font-weight: 800;
      letter-spacing: -.03em;
    }

    .review-meta {
      color: var(--soft);
      font-size: .82rem;
      margin-top: 4px;
    }

    .quote {
      color: #e8ecf5;
      line-height: 1.7;
      margin: 0;
    }

    .faq-grid {
      display: grid;
      grid-template-columns: .78fr 1.22fr;
      gap: 28px;
      align-items: start;
    }

    .faq-aside {
      position: sticky;
      top: 104px;
      border-radius: var(--radius);
      padding: 26px;
      background: rgba(255,255,255,.05);
      border: 1px solid rgba(255,255,255,.1);
    }

    .faq-aside p {
      color: var(--muted);
      line-height: 1.7;
      margin: 14px 0 0;
    }

    .accordion {
      display: grid;
      gap: 12px;
    }

    .faq-item {
      border-radius: 19px;
      border: 1px solid rgba(255,255,255,.11);
      background: rgba(255,255,255,.05);
      overflow: hidden;
    }

    .faq-question {
      width: 100%;
      text-align: left;
      border: 0;
      color: var(--text);
      background: transparent;
      padding: 20px 22px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 18px;
      font-size: 1rem;
      font-weight: 800;
      cursor: pointer;
      letter-spacing: -.025em;
    }

    .plus {
      width: 28px;
      height: 28px;
      flex: 0 0 auto;
      border-radius: 999px;
      display: grid;
      place-items: center;
      background: rgba(255,255,255,.08);
      transition: transform .24s ease;
      color: var(--purple);
    }

    .faq-answer {
      max-height: 0;
      overflow: hidden;
      transition: max-height .3s ease;
    }

    .faq-answer p {
      margin: 0;
      padding: 0 22px 20px;
      color: var(--muted);
      line-height: 1.7;
    }

    .faq-item.active .plus { transform: rotate(45deg); }
    .faq-item.active .faq-answer { max-height: 220px; }

    .cta-band {
      padding: 34px;
      border-radius: calc(var(--radius) + 8px);
      background:
        radial-gradient(circle at 16% 10%, rgba(139,92,246,.22), transparent 28rem),
        radial-gradient(circle at 86% 40%, rgba(192,132,252,.17), transparent 26rem),
        linear-gradient(180deg, rgba(255,255,255,.085), rgba(255,255,255,.045));
      border: 1px solid rgba(255,255,255,.12);
      box-shadow: var(--shadow);
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 26px;
      align-items: center;
    }

    .cta-band h2 { font-size: clamp(2rem, 4.2vw, 4.4rem); }
    .cta-band p {
      max-width: 690px;
      color: var(--muted);
      line-height: 1.72;
      margin: 16px 0 0;
    }

    footer {
      padding: 36px 0;
      color: var(--soft);
      border-top: 1px solid rgba(255,255,255,.08);
    }

    .footer-inner {
      display: flex;
      justify-content: space-between;
      gap: 22px;
      align-items: center;
      flex-wrap: wrap;
      font-size: .9rem;
    }

    .footer-links {
      display: flex;
      gap: 16px;
      flex-wrap: wrap;
    }

    .reveal {
      opacity: 0;
      transform: translateY(24px);
      transition: opacity .7s ease, transform .7s ease;
    }

    .reveal.show {
      opacity: 1;
      transform: translateY(0);
    }

    .delay-1 { transition-delay: .08s; }
    .delay-2 { transition-delay: .16s; }
    .delay-3 { transition-delay: .24s; }

    @media (max-width: 980px) {
      .hero-grid,
      .faq-grid,
      .cta-band {
        grid-template-columns: 1fr;
      }

      .features,
      .pricing-grid {
        grid-template-columns: 1fr;
      }

      .process {
        grid-template-columns: repeat(2, 1fr);
      }

      .review {
        flex-basis: 50%;
      }

      .section-head {
        align-items: flex-start;
        flex-direction: column;
      }
    }

    @media (max-width: 760px) {
      .nav-links {
        position: fixed;
        left: 20px;
