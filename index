    .feature-card::after,
    .plan::after,
    .review-card::after,
    .step::after {
      content: "";
      position: absolute;
      inset: 0;
      pointer-events: none;
      background:
        linear-gradient(135deg, rgba(255,255,255,.12), transparent 34%),
